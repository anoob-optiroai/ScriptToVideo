# ScriptToVideo — API Keys Configuration
# Edit this file and restart the app to apply changes.
# Location: %APPDATA%\ScriptToVideo\.env  (Windows)
#           ~/Library/Application Support/ScriptToVideo/.env  (Mac)

# ── TTS Provider: "elevenlabs", "openai", or "google" ────────────────────────
TTS_PROVIDER=elevenlabs

# ── API Keys (fill in at least one TTS provider) ─────────────────────────────
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
GOOGLE_CLOUD_API_KEY=

# ── Google Docs import (optional) ────────────────────────────────────────────
GOOGLE_DOCS_API_KEY=
