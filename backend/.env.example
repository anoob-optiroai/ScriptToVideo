# ── TTS Provider ────────────────────────────────────────────────────────────
# Choose one: elevenlabs | openai | google
TTS_PROVIDER=elevenlabs

# ── API Keys (fill in the one matching your TTS_PROVIDER) ───────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CLOUD_API_KEY=your_google_cloud_api_key_here

# ── Google Docs (for importing scripts from Google Doc URLs) ─────────────────
# Leave blank if you share docs as "Anyone with the link can view"
GOOGLE_DOCS_API_KEY=

# ── Output directories ────────────────────────────────────────────────────────
AUDIO_OUTPUT_DIR=outputs/audio
VIDEO_OUTPUT_DIR=outputs/video
UPLOAD_DIR=uploads

# ── CORS — add your frontend URL ──────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── FFmpeg / LibreOffice ──────────────────────────────────────────────────────
# On Windows, provide full path if not in PATH:
# FFMPEG_BINARY=C:\ffmpeg\bin\ffmpeg.exe
# LIBREOFFICE_BINARY=C:\Program Files\LibreOffice\program\soffice.exe
FFMPEG_BINARY=ffmpeg
LIBREOFFICE_BINARY=libreoffice
