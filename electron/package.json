{
  "name": "scripttovideo",
  "version": "1.1.7",
  "description": "Convert PowerPoint slides with audio narration into synchronized MP4 videos",
  "main": "main.js",
  "author": "ScriptToVideo",
  "license": "MIT",
  "scripts": {
    "start":       "electron .",
    "build:win":   "electron-builder --win",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron":         "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.scripttovideo.app",
    "productName": "ScriptToVideo",

    "directories": {
      "output": "../dist_electron"
    },

    "files": [
      "main.js",
      "assets/**"
    ],

    "extraResources": [
      {
        "from": "../backend/dist/scriptovideo-backend/",
        "to":   "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../ffmpeg_bin/",
        "to":   "ffmpeg",
        "filter": ["**/*"]
      }
    ],

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch":   ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },

    "nsis": {
      "oneClick":               false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":  true,
      "createStartMenuShortcut": true,
      "shortcutName":           "ScriptToVideo",
      "installerIcon":          "assets/icon.ico",
      "uninstallerIcon":        "assets/icon.ico",
      "installerHeaderIcon":    "assets/icon.ico"
    },

    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch":   ["x64", "arm64"]
        }
      ],
      "icon":     "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },

    "dmg": {
      "title":   "${productName} ${version}",
      "icon":    "assets/icon.icns",
      "window":  { "width": 540, "height": 380 },
      "contents": [
        { "x": 140, "y": 200, "type": "file"    },
        { "x": 400, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },

    "linux": {
      "target": ["AppImage"],
      "icon":   "assets/icon.png",
      "category": "Office"
    },

    "publish": {
      "provider": "github",
      "owner":    "anoob-optiroai",
      "repo":     "ScriptToVideo",
      "releaseType": "release"
    }
  }
}
